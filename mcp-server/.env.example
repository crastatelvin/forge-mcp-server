# ============================================

# --- Authentication ---
# When set, every request (except /health, /, /docs, /openapi.json) must include
#   Authorization: Bearer <key>
# Leave blank in local development for open access.
FORGE_API_KEY=

# --- Anthropic (enables /chat endpoint in the dashboard) ---
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Weather ---
# Optional: OpenWeatherMap API key. If unset, FORGE falls back to wttr.in.
WEATHER_API_KEY=

# --- Filesystem sandbox ---
# Comma-separated list of directories tools are allowed to read/write/list.
# Paths are resolved to absolute paths at runtime.
ALLOWED_DIRS=./storage,./workspace

# Max file size in megabytes for read_file
MAX_FILE_SIZE_MB=10

# --- CORS ---
# Use "*" for local dev. Set to your dashboard URL in production.
# CORS_ORIGINS=https://your-dashboard.vercel.app
CORS_ORIGINS=*

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MIN=120
